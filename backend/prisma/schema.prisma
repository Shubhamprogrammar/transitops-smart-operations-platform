generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(FLEET_MANAGER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id         Int           @id @default(autoincrement())
  regNumber  String        @unique
  capacity   Int
  status     VehicleStatus @default(AVAILABLE)
  createdAt  DateTime      @default(now())
  trips      Trip[]
}

model Driver {
  id            Int          @id @default(autoincrement())
  name          String
  licenseNumber String       @unique
  expiryDate    DateTime
  status        DriverStatus @default(AVAILABLE)
  createdAt     DateTime     @default(now())
  trips         Trip[]
}

model Trip {
  id          Int         @id @default(autoincrement())
  vehicleId   Int
  driverId    Int
  cargoWeight Int
  distance    Int?
  status      TripStatus  @default(DRAFT)
  startTime   DateTime?
  endTime     DateTime?
  createdAt   DateTime    @default(now())
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id])
  driver      Driver      @relation(fields: [driverId], references: [id])
}
